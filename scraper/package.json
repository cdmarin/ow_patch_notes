{
  "name": "ow-patch-scraper",
  "version": "1.0.0",
  "description": "Scraper de patch notes de Overwatch con traducción automática via LibreTranslate",
  "main": "scraper.js",
  "scripts": {
    "start": "node ../server.js",
    "scrape": "node scraper.js --patch=latest",
    "scraper": "node scraper.js --patch=latest",
    "scrape:latest": "node scraper.js --patch=latest",
    "scrape:all": "node scraper.js --all"
  },
  "dependencies": {
    "@xenova/transformers": "^2.0.1",
    "axios": "^1.7.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0",
    "fs-extra": "^11.2.0",
    "yargs": "^17.7.2"
  }
}